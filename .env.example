# Core server settings
PORT=4000
LOG_LEVEL=info
NODE_ENV=development

# Vault storage
# VAULT_ROOT defaults to "<cwd>/vault" if not set.
VAULT_ROOT=/Users/foundry/foundry/foundry-data-dev/Data
# VAULT_DB_PATH defaults to "<cwd>/data/vaultapi.sqlite" if not set.
VAULT_DB_PATH=/Users/foundry/Documents/development/foundryvtt/vaultapi/data/vaultapi.sqlite
VAULT_API_KEY=dev-key

# CORS (comma-separated origins)
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# Foundry paths
FOUNDRY_DATA_ROOT=/Users/foundry/foundry/foundry-data-dev/Data
FOUNDRY_PUBLIC_ROOT=/Users/foundry/foundry/foundryvtt/public

# Session/auth
SESSION_SECRET=change-me-in-production
SESSION_DB_DIR=/Users/foundry/Documents/development/foundryvtt/vaultapi/data
SESSION_DB_NAME=vaultapi-sessions.sqlite

# Bootstrap admin (used if auth DB is empty)
BOOTSTRAP_ADMIN_USERNAME=admin
# Optional legacy fallback (username is preferred)
# BOOTSTRAP_ADMIN_EMAIL=admin
BOOTSTRAP_ADMIN_PASSWORD=change_me

# Optional actor identity used when API key auth creates an actor command context
# API_KEY_ACTOR_USER_ID=

